# Other sources
source "$DOTFILES"/home/zsh/oh-my-zsh.zsh
source "$DOTFILES"/home/zsh/aliases.zsh

# Opts
setopt extendedglob
setopt globdots
zstyle ':completion:*' special-dirs false

# Tool inits (PATH, pyenv, bun, etc.) — alphabetical order
for f in $DOTFILES/home/zsh/init/*.zsh(N); do source "$f"; done
