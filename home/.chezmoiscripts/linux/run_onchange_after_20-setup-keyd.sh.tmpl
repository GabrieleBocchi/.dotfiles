#!/usr/bin/env bash

set -euo pipefail

# Checksum to let run_onchange detect config changes
# sha256: {{ sha256sum (include "keyboard/default.conf") }}

if [ ! -d /run/systemd/system ]; then
    echo "− Skipping keyd (no systemd)"
    exit 0
fi

echo "▸ Setting up keyd"
if ! command -v keyd &>/dev/null; then
    echo "▸ Installing keyd from source..."
    build_dir=$(mktemp -d)
    git clone --depth 1 https://github.com/rvaiya/keyd "$build_dir"
    make -C "$build_dir"
    sudo make -C "$build_dir" install
    rm -rf "$build_dir"
    sudo systemctl enable keyd
fi

src="{{ .chezmoi.sourceDir }}/keyboard/default.conf"

if [[ ! -f /etc/keyd/default.conf ]] || ! diff -q "$src" /etc/keyd/default.conf &>/dev/null; then
    sudo mkdir -p /etc/keyd
    sudo cp "$src" /etc/keyd/default.conf
    sudo systemctl restart keyd
fi
echo "✓ Keyd"
