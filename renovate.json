{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinDependencies",
    "group:allNonMajor",
    "mergeConfidence:all-badges",
    "security:openssf-scorecard",
    ":semanticCommits",
    ":disableDependencyDashboard"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^home/\\.chezmoiexternal\\.toml$"],
      "matchStrings": [
        "url\\s*=\\s*\"https://github\\.com/(?<depName>[^/]+/[^/]+)/archive/refs/tags/(?<currentValue>v[0-9][^/\"]+)\\.tar\\.gz\"",
        "url\\s*=\\s*\"https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>v[0-9][^/\"]+)/[^\"]+\""
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^\\.chezmoiversion$"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "twpayne/chezmoi",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
